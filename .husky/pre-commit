#!/usr/bin/env sh

# Auto-fix staged files with biome
biome check --staged --write --no-errors-on-unmatched

# Re-stage any fixed files
git update-index --again

# Verify the staged files are clean (fail if there are remaining issues)
biome check --staged --no-errors-on-unmatched

# Run affected project checks
npx nx affected -t lint test build --base=HEAD --parallel=3
