{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generated Postman Collection",
  "description": "JSON Schema for the Postman collection output generated by this feature",
  "type": "object",
  "required": ["info", "item"],
  "properties": {
    "info": {
      "type": "object",
      "required": ["name", "schema"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Collection name derived from OpenAPI info.title"
        },
        "description": {
          "type": "string",
          "description": "Collection description from OpenAPI info.description"
        },
        "schema": {
          "type": "string",
          "const": "https://schema.postman.com/json/collection/v2.1.0/collection.json"
        }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["bearer", "apikey", "basic", "noauth"]
        },
        "bearer": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    },
    "variable": {
      "type": "array",
      "description": "Collection-level variables",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "item": {
      "type": "array",
      "description": "Folders (by tags) containing requests",
      "items": {
        "$ref": "#/definitions/folder"
      }
    }
  },
  "definitions": {
    "folder": {
      "type": "object",
      "required": ["name", "item"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Folder name from OpenAPI tag"
        },
        "description": {
          "type": "string"
        },
        "item": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/request"
          }
        }
      }
    },
    "request": {
      "type": "object",
      "required": ["name", "request"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Request name from operationId or summary"
        },
        "request": {
          "type": "object",
          "required": ["method", "url"],
          "properties": {
            "method": {
              "type": "string",
              "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"]
            },
            "url": {
              "type": "object",
              "properties": {
                "raw": { "type": "string" },
                "host": { "type": "array", "items": { "type": "string" } },
                "path": { "type": "array", "items": { "type": "string" } },
                "query": { "type": "array", "items": { "$ref": "#/definitions/parameter" } },
                "variable": { "type": "array", "items": { "$ref": "#/definitions/parameter" } }
              }
            },
            "header": {
              "type": "array",
              "items": { "$ref": "#/definitions/parameter" }
            },
            "body": {
              "type": "object",
              "properties": {
                "mode": { "type": "string", "enum": ["raw", "formdata", "urlencoded", "file"] },
                "raw": { "type": "string" },
                "options": {
                  "type": "object",
                  "properties": {
                    "raw": {
                      "type": "object",
                      "properties": {
                        "language": { "type": "string", "enum": ["json", "xml", "text"] }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "parameter": {
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "description": { "type": "string" },
        "disabled": { "type": "boolean" }
      }
    }
  }
}
