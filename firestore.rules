rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Allow read if authenticated user is reading their own document
      // or if user is admin
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.role == 'admin');

      // Only admins can write to user documents
      allow write: if request.auth != null &&
        request.auth.token.role == 'admin';
    }

    // Brackets collection — all writes go through NestJS API (Admin SDK bypasses rules)
    match /brackets/{bracketId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
